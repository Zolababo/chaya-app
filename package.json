{
  "name": "chaya-platform",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "verify": "turbo lint && turbo build",
    "audit": "pnpm audit --audit-level=moderate",
    "smoke:consumer": "node ./scripts/smoke-consumer-menu.mjs",
    "smoke:merchant": "node ./scripts/smoke-merchant-parallel.mjs",
    "smoke:platform": "node ./scripts/smoke-platform.mjs",
    "a11y:baseline": "node ./scripts/check-a11y-baseline.mjs",
    "crud:generate": "node ./scripts/generate-crud.mjs",
    "crud:menu": "node ./scripts/generate-crud.mjs menu",
    "crud:category": "node ./scripts/generate-crud.mjs category",
    "cutover:check": "node ./scripts/check-merchant-cutover-readiness.mjs",
    "stability:report": "node ./scripts/generate-stability-report.mjs",
    "stability:cycle": "node ./scripts/run-stability-cycle.mjs",
    "cert:pack": "node ./scripts/generate-cert-readiness-pack.mjs"
  },
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}
