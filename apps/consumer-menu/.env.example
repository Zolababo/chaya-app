# Safe to expose in client bundle (NEXT_PUBLIC_*).
# Copy values from Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 권장: 프로덕션 커스텀 도메인·모바일 공유 시 메타 URL 고정 (metadataBase·OG·푸시/메일 링크).
# 미설정 시 서버는 Vercel이면 VERCEL_PROJECT_PRODUCTION_URL(고정 프로덕션 호스트) → VERCEL_URL 순. 푸시 링크가 배포 보호 URL로 가지 않게 하려면 명시 권장.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# NEXT_PUBLIC_LEGACY_MERCHANT_URL=https://chaya-menu-test.vercel.app
# 점주 화면에 내부·개발자 안내(ARCHITECTURE, env 이름 등) 표시. 기본 미설정 = 점주용 UI만.
# NEXT_PUBLIC_MERCHANT_INTERNAL_UI=true

# Consumer menu reads `ChayaMenus` with the anon key (filtered by `tenant_slug` = URL segment).
# Merchandising flags (오늘의 메뉴·사장님 Pick): `supabase/migrations/20260519120000_chaya_menus_merchandising_flags.sql`
# 메뉴 created_at (신규 스티커): `supabase/migrations/20260519140000_chaya_menus_created_at.sql`
# 주문 번호 order_no (KST 영업일별 01, 02 …): `20260519150000_*` + `20260519160000_*` + `20260519170000_order_daily_counter_rls_fix.sql`
# Apply repo migration `supabase/migrations/20260415130000_chaya_menus_tenant_slug.sql` on your project.
# Ensure RLS allows anon SELECT on that table (or a safe view), or reads will fail and the UI falls back to demo data.
#
# C6 — 테이블 QR 서명·만료 (장난·외부 주문 방지). 프로덕션 권장. 미설정 시 로컬만 검증 스킵.
# CONSUMER_TABLE_QR_TOKEN_SECRET=   # 16자 이상 랜덤. Vercel Production에 설정.
# CONSUMER_TABLE_QR_TOKEN_TTL_HOURS=4 # QR 링크 유효 시간(기본 4시간, 최대 168).
#
# listing or deleting orders from legacy admin needs the service role key or updated policies.
# Order detail JSON: `20260425153000_get_order_for_guest_rpc.sql` then `20260506120000_get_order_for_guest_session_match.sql` (same session rule as status RPC; app sets `chaya_guest_session` cookie).
# Status-only poll (lighter): `20260428140000_get_order_status_for_guest_rpc.sql` then
# `20260505140000_get_order_status_for_guest_session_match.sql` — orders with guest_session_id require matching browser session.
# Consumer experience events (QR·메뉴·주문): `20260604120000_consumer_experience_events.sql` — INSERT는 SERVICE_ROLE만.
# 점주 손님·재방문: `20260606120000_merchant_guest_visits.sql` — completed_at, store_visits, tenant_guest_rollups.
# Order list tab: apply `20260428120000_list_orders_for_guest_rpc.sql` (RPC list_orders_for_guest).
# Optional perf: `20260428123000_idx_orders_tenant_guest_created.sql` — index for that RPC.
# Optional: `20260425160000_orders_table_note_status.sql` — table_no, guest_note, status + stricter INSERT RLS.
# 테이블 마스터·QR·주문 검증: `20260522120000_tenant_tables.sql` — tenant_tables + RPC tenant_table_is_valid.
#
# Merchant `/m/*`: Supabase Auth + `merchant_tenant_members`(마이그레이션 `20260510183000_*`, 승인 컬럼 `20260512120000_merchant_tenant_members_approved_at.sql`). 초대는 `/ops/merchants` 또는 SQL.
# 점주 비밀번호 찾기/재설정: Auth Redirect URLs에 `{SITE}/m/auth/confirm` 추가 — `docs/MERCHANT_ACCOUNT_PASSWORD.md`
# 기본: 이메일·비밀번호 로그인 + `/ops/merchants` 에서 이메일·임시 비밀번호 초대. SMS 점주 로그인을 쓰려면 아래를 true 로 두고 Phone·Twilio 설정.
# NEXT_PUBLIC_MERCHANT_LOGIN_SMS=true
# Platform `/ops/*`: `platform_operators`(마이그레이션 `20260510210000_*`). 점주 계정 생성에 Admin API(서비스 롤) 필요.
# Vercel Production 필수(SERVICE ROLE): 점주 주문·메뉴 및 `/ops` 신규 점주 `createUser`.
# SUPABASE_SERVICE_ROLE_KEY=   # Project Settings → API → service_role (secret). SUPABASE_SECRET_KEY 별칭도 인식합니다.
# `/health` 가 매 초 호출되는 환경에서 DB RPC 프로브(손님 주문 3종) 부하를 줄이려면 1 로 설정합니다.
# CHAYA_HEALTH_SKIP_GUEST_RPC_PROBE=1
#
# 루트 `/` 를 손님·점주 선택 화면으로 유지 (기본은 `/t/demo` 로 바로 이동).
# CHAYA_ROOT_ROLE_PICKER=1
#
# Phase 3 (선택): 손님 신규 주문 시 점주 이메일 알림 — Resend. `merchant_tenant_members.invite_email` 이 있는 승인 멤버에게만 발송.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev   # Resend에서 검증된 발신 주소
#
# AI 자동 번역 (한식진흥원 DB 미매칭 메뉴명 → Gemini 번역 → Supabase 캐시 저장).
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
# 키는 AQ… 또는 AIzaSy… 형식 모두 가능 (2026년 AI Studio 신규 키는 AQ…).
# Vercel Environment Variables → GEMINI_API_KEY (또는 GOOGLE_API_KEY) → Production → Redeploy 필수.
# DB: supabase/migrations/20260601120000_menu_translation_cache.sql (+ 130000 locale desc)
# GEMINI_API_KEY=
#
# Phase 3 (선택): 웹 푸시 — `npx web-push generate-vapid-keys` 로 키 생성 후 아래 3개 + DB `20260512220000_merchant_push_subscriptions.sql`.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@yourdomain.com
#
# 미처리 주문 백그라운드 푸시 재알림: 임의 문자열. 외부 cron(1분)이 호출 — Authorization: Bearer <CRON_SECRET>
# GET https://chaya-app.vercel.app/api/cron/merchant-pending-push
# Vercel Hobby는 분 단위 Vercel Cron 불가 → cron-job.org 등 무료 스케줄러 사용. Pro면 vercel.json crons 추가 가능.
# CRON_SECRET=
# Phase 3 (선택): 카카오 알림톡 등 — 자체 Edge/서버 URL로 JSON POST (Bearer 선택). 본 레포는 전송 로직만 제공합니다.
# MERCHANT_ORDER_NOTIFY_WEBHOOK_URL=
# MERCHANT_ORDER_NOTIFY_WEBHOOK_SECRET=
# 연동 완료 표시: Supabase `tenant_store_settings.kakao_alimtalk_linked_at` (마이그레이션 20260602120000)
# Ops 데모 주문 초기화: 기본 `demo` 허용. 추가 매장은 쉼표 구분 (예: pilot-store)
# OPS_ORDER_RESET_ALLOWED_TENANTS=
# 플랜: `tenant_store_settings.billing_plan` (마이그레이션 20260603130000)
# SUPABASE_URL=                # 선택: NEXT_PUBLIC_SUPABASE_URL 과 동일 프로젝트 URL (서버 전용 복제본을 쓸 때)
# SUPABASE_MENU_IMAGES_BUCKET= # optional; default `menu-images` — must exist & allow service_role upload + public read for URLs
# Menu order: apply `20260425200000_chaya_menus_sort_order.sql` then optional `20260425210000_chaya_menus_sort_order_check.sql` (CHECK).
# Legacy `restaurant_slug` only: run `20260425220000_chaya_menus_tenant_slug_from_restaurant_slug.sql` so `tenant_slug` matches the app.
